// Listing image cards — Templix Etsy gallery
// Visual system matches the Canva reference:
//   - Deep aubergine background, lavender accent boxes
//   - Heavy bold sans-serif (Sora) display + Instrument Serif italic accents
//   - "LIMITED TIME 50% OFF" ribbon top-left
//   - TemplixStudios wordmark + tier pill top
//   - Tablet mockups fanned across the middle
//   - "Key Features" panel + 3 line-icon tiles at bottom

// ── Per-tier palette ────────────────────────────────────────────────────
const TIER = {
  Plus: {
    bg: '#2C1A3D', // deep aubergine
    bgGrad: '#3A2353',
    accent: '#A98CC9', // lavender (ribbon, pill, boxes)
    accent2: '#8F6FBA',
    on: '#FFFFFF'
  },
  Pro: {
    bg: '#15302A', // deep forest
    bgGrad: '#1F4438',
    accent: '#8FBFA6', // sage
    accent2: '#6BA689',
    on: '#FFFFFF'
  },
  Ultimate: {
    bg: '#2A1F12', // deep bronze
    bgGrad: '#3D2D1A',
    accent: '#D59006', // amber gold
    accent2: '#A6700A',
    on: '#FFFFFF'
  }
};
window.TIER = TIER;

// ── CSV-driven content helpers ──────────────────────────────────────────
// getFeatures(bundle, cardId, defaults) → array, with overrides feature_1..feature_N
// getTiles(bundle, cardId, defaults)   → array of {icon, label}, with tile_N_icon / tile_N_label
function getFeatures(bundle, cardId, defaults) {
  const get = window.getCardContent;
  if (!get) return defaults;
  return defaults.map((d, i) => get(bundle.id, cardId, `feature_${i + 1}`, d, bundle)).filter(Boolean);
}
function getTiles(bundle, cardId, defaults) {
  const get = window.getCardContent;
  if (!get) return defaults;
  return defaults.map((d, i) => ({
    icon: get(bundle.id, cardId, `tile_${i + 1}_icon`, d.icon, bundle),
    label: get(bundle.id, cardId, `tile_${i + 1}_label`, d.label, bundle)
  }));
}

const tone = (b) => TIER[b.tier] || TIER.Plus;

// ── Frame ───────────────────────────────────────────────────────────────
function CardFrame({ bundle, children }) {
  const t = tone(bundle);
  return (
    <div style={{
      position: 'relative',
      width: 2000, height: 2000,
      background: `radial-gradient(ellipse at 50% 30%, ${t.bgGrad} 0%, ${t.bg} 70%)`,
      color: t.on,
      fontFamily: 'Sora, system-ui, sans-serif',
      overflow: 'hidden'
    }}>
      {children}
    </div>);

}

// ── Ribbon ──────────────────────────────────────────────────────────────
function Ribbon({ bundle, off = 50, accent }) {
  if (window.RIBBON_HIDDEN) return null;
  const t = tone(bundle);
  const fg = accent || t.accent;
  // Slightly darker tone for the shadow side
  const shade = `color-mix(in oklab, ${fg} 80%, #000 20%)`;
  return (
    <div style={{
      position: 'absolute', top: 0, left: 80,
      width: 300, height: 360,
      filter: 'drop-shadow(0 30px 30px rgba(0,0,0,0.45))'
    }}>
      {/* Ribbon body with notched bottom (proper triangle fold) */}
      <svg width="100%" height="100%" viewBox="0 0 300 360" preserveAspectRatio="none"
      style={{ position: 'absolute', inset: 0 }}>
        <defs>
          <linearGradient id="ribGrad" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0" stopColor={fg} />
            <stop offset="1" stopColor={shade} />
          </linearGradient>
        </defs>
        {/* Main body */}
        <path d="M0 0 L300 0 L300 312 L150 282 L0 312 Z" fill="url(#ribGrad)" />
        {/* Subtle highlight stripe on the left for a faceted look */}
        <path d="M0 0 L40 0 L40 312 L20 306 L0 312 Z" fill="rgba(255,255,255,0.08)" />
      </svg>

      {/* Text content — original two-line style */}
      <div style={{
        position: 'absolute', inset: 0,
        display: 'flex', flexDirection: 'column', alignItems: 'center',
        justifyContent: 'flex-start', paddingTop: 56,
        color: '#FFFFFF', textAlign: 'center',
        fontWeight: 700
      }}>
        <div style={{
          fontSize: 30, letterSpacing: '0.08em', fontWeight: 600
        }}>LIMITED TIME</div>
        <div style={{
          marginTop: 18, fontSize: 82, fontWeight: 800, lineHeight: 0.95
        }}>{off}%<br />OFF</div>
      </div>
    </div>);

}

// ── Tier Pill ───────────────────────────────────────────────────────────
function TierPill({ bundle, size = 60 }) {
  const t = tone(bundle);
  return (
    <div style={{
      display: 'inline-block',
      padding: `${size * 0.35}px ${size * 0.95}px`,
      background: t.accent,
      color: '#FFFFFF',
      fontWeight: 700, fontSize: size,
      letterSpacing: '0.06em',
      borderRadius: 999,
      textTransform: 'uppercase'
    }}>{bundle.tier}</div>);

}

// ── Tablet mockup — use the Move Master bezel + composite cover on screen
function Tablet({ src, width = 460, tilt = 0, z = 1 }) {
  const height = width * 1.575; // bezel aspect (869×1369)
  // Screen inset measured from tablet-bezel.png alpha
  const inset = { top: 4.2, right: 19.6, bottom: 12.7, left: 7.1 };
  return (
    <div style={{
      width, height,
      transform: `rotate(${tilt}deg)`,
      zIndex: z,
      position: 'relative',
      filter: 'drop-shadow(0 40px 50px rgba(0,0,0,0.55))'
    }}>
      {/* Screen content underneath */}
      {src &&
      <div style={{
        position: 'absolute',
        top: `${inset.top}%`,
        left: `${inset.left}%`,
        right: `${inset.right}%`,
        bottom: `${inset.bottom}%`,
        backgroundColor: '#FFFFFF',
        backgroundImage: `url("${src}")`,
        backgroundSize: 'contain',
        backgroundPosition: 'top center',
        backgroundRepeat: 'no-repeat',
        overflow: 'hidden'
      }} />
      }
      {/* Bezel on top */}
      <img src="generator/tablet-bezel.png" alt=""
      style={{ position: 'absolute', inset: 0, width: '100%', height: '100%', pointerEvents: 'none' }} />
    </div>);

}

// ── Header chrome (Designed for reMarkable + Wordmark + Pill) ───────────
function HeaderChrome({ bundle, sub }) {
  const t = tone(bundle);
  return (
    <div style={{
      position: 'absolute', top: 60, left: 0, right: 0,
      display: 'flex', flexDirection: 'column', alignItems: 'center',
      textAlign: 'center', color: t.on
    }}>
      {sub &&
      <div style={{ fontSize: 50, fontWeight: 500, letterSpacing: '0.005em' }}>
          {sub.before}
          <em style={{
          fontFamily: '"Instrument Serif", serif', fontStyle: 'italic',
          fontWeight: 400, fontSize: 60
        }}>{sub.italic}</em>
          {sub.after}
        </div>
      }
      <div style={{
        marginTop: sub ? 40 : 0,
        display: 'flex', alignItems: 'center', gap: 30
      }}>
        <span style={{ fontSize: 70, fontWeight: 600, letterSpacing: '-0.01em' }}>
          TemplixStudios
        </span>
        <TierPill bundle={bundle} size={42} />
      </div>
    </div>);

}

// ── Flag chips for "5 Language Systems" ─────────────────────────────────
function LangFlags() {
  const flags = [
  { code: 'EN', stripes: ['#012169', '#FFFFFF', '#C8102E'] },
  { code: 'IT', stripes: ['#008C45', '#F4F5F0', '#CD212A'] },
  { code: 'DE', stripes: ['#000000', '#DD0000', '#FFCE00'] },
  { code: 'ES', stripes: ['#AA151B', '#F1BF00', '#AA151B'] },
  { code: 'FR', stripes: ['#0055A4', '#FFFFFF', '#EF4135'] }];

  return (
    <span style={{ display: 'inline-flex', gap: 10, marginLeft: 14, verticalAlign: 'middle' }}>
      {flags.map((f) =>
      <span key={f.code} title={f.code} style={{
        display: 'inline-flex',
        width: 40, height: 28, borderRadius: 4, overflow: 'hidden',
        border: '1.5px solid rgba(255,255,255,0.35)'
      }}>
          {f.stripes.map((c, i) =>
        <span key={i} style={{ flex: 1, background: c }} />
        )}
        </span>
      )}
    </span>);

}

// ── Bottom info panels ──────────────────────────────────────────────────
function BottomPanels({ bundle, features, icons }) {
  const t = tone(bundle);
  return (
    <div style={{
      position: 'absolute', bottom: 100, left: 100, right: 100,
      display: 'grid', gridTemplateColumns: '1.15fr 1fr', gap: 40
    }}>
      {/* Key Features panel */}
      <div style={{
        background: t.accent, color: '#FFFFFF',
        borderRadius: 32, padding: '44px 52px',
        display: 'flex', flexDirection: 'column', gap: 18
      }}>
        <div style={{ display: 'flex', alignItems: 'center', gap: 20 }}>
          <ClipboardIcon />
          <span style={{ fontWeight: 700, fontSize: "45px" }}>Key Features</span>
        </div>
        {features.map((f, i) =>
        <div key={i} style={{ display: 'flex', alignItems: 'center', gap: 20 }}>
            <CheckIcon size={32} />
            <span style={{ fontWeight: 500, fontSize: "34px" }}>
              {f}
              {/Language|Lang/i.test(f) && <LangFlags />}
            </span>
          </div>
        )}
      </div>

      {/* Icon tiles */}
      <div style={{
        background: t.accent, color: '#FFFFFF',
        borderRadius: 32, padding: '44px 36px',
        display: 'grid', gridTemplateColumns: '1fr 1fr 1fr', gap: 20,
        alignItems: 'end'
      }}>
        {icons.map((it, i) =>
        <div key={i} style={{
          display: 'flex', flexDirection: 'column', alignItems: 'center', gap: 24,
          textAlign: 'center'
        }}>
            <div style={{
            width: 200, height: 200,
            display: 'flex', alignItems: 'center', justifyContent: 'center'
          }}>
              {typeof it.icon === 'string' ?
            window.ICONS?.[it.icon] ? React.createElement(window.ICONS[it.icon]) : null :
            it.icon}
            </div>
            <div style={{ fontSize: 30, fontWeight: 500, lineHeight: 1.2 }}>
              {it.label.split('\n').map((line, j) =>
            <div key={j}>{line}</div>
            )}
            </div>
          </div>
        )}
      </div>
    </div>);

}

