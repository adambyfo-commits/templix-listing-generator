// ── Pick N key page URLs for a product, skipping covers/blanks ──────────
function pickKeyPages(productId, n) {
  const all = window.TEMPLIX_PAGES?.[productId] || [];
  // Skip cover + table-of-contents — those aren't "key pages"
  const filtered = all.filter((p) =>
  p.pageKey !== 'cover' &&
  !/^toc/.test(p.pageKey) &&
  p.url
  );
  if (!filtered.length) return [];
  // Spread N picks across the available pages so we get variety
  const step = Math.max(1, Math.floor(filtered.length / n));
  const out = [];
  for (let i = 0; i < n; i++) {
    out.push(filtered[Math.min(i * step, filtered.length - 1)]?.url);
  }
  return out;
}

// ── Card 01 · Hero (bundle overview) ────────────────────────────────────
function HeroCard({ bundle, products, title }) {
  const totalPages = products.reduce((s, p) => s + (parseInt(p.galleryImages, 10) || 0), 0);
  const tagline = title || bundle.heroTagline;
  // Fan: 5 tablets. Pull one key (non-cover) page per product, cycling through products.
  const fanCount = 5;
  const tablets = Array.from({ length: fanCount }, (_, i) => {
    const mid = (fanCount - 1) / 2;
    const off = i - mid;
    const dist = Math.abs(off);
    const w = 560 - dist * 36;
    const product = products[i % products.length];
    // pick a different key page index per slot so the same product shows different pages
    const productSlotIndex = Math.floor(i / Math.max(1, products.length));
    const keyPages = product ? pickKeyPages(product.id, 5) : [];
    const src = keyPages[productSlotIndex % keyPages.length] || product?.sampleUrl;
    return {
      src,
      width: w,
      x: off * 330,
      y: dist * 32,
      z: fanCount - dist
    };
  });

  return (
    <CardFrame bundle={bundle}>
      <Ribbon bundle={bundle} />

      <HeaderChrome
        bundle={bundle}
        sub={{ before: 'Designed for ', italic: 'reMarkable', after: ' Pro Move Devices' }} />
      

